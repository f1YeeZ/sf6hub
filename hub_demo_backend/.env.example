DB_URL=jdbc:postgresql://localhost:5432/hub_demo
DB_USERNAME=hub_demo
DB_PASSWORD=replace-with-a-strong-password
DB_MAX_POOL_SIZE=10
APP_ENV=beta

JWT_SECRET=replace-with-at-least-32-random-characters

QQ_MAIL_USERNAME=your-mailbox@example.com
QQ_MAIL_AUTH_CODE=mail-provider-app-password
QQ_MAIL_FROM=your-mailbox@example.com

PUBLIC_BASE_URL=https://api.example.com/api
CORS_ALLOWED_ORIGIN_PATTERNS=https://example.com,https://www.example.com
TRUSTED_PROXY_ADDRESSES=

# 本地开发保持 local；上线切换为 oss 后不再使用 UPLOAD_DIR 提供新文件。
STORAGE_PROVIDER=local
UPLOAD_DIR=/var/lib/hub-demo/uploads
UPLOAD_USER_QUOTA_BYTES=1073741824
UPLOAD_ORPHAN_RETENTION_HOURS=24
UPLOAD_CLEANUP_CRON=0 30 4 * * *
MAX_FILE_SIZE=100MB
MAX_REQUEST_SIZE=100MB

# STORAGE_PROVIDER=oss 时必填。OSS_PUBLIC_BASE_URL 建议填写已绑定 OSS 回源的 CDN HTTPS 域名。
OSS_ENDPOINT=https://oss-cn-shanghai.aliyuncs.com
OSS_BUCKET=replace-with-your-private-bucket
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
# 使用 STS 临时凭证时填写；长期 AccessKey 留空即可。
OSS_SECURITY_TOKEN=
OSS_PUBLIC_BASE_URL=https://cdn.example.com

REALTIME_MAX_PUBLIC_CONNECTIONS=2000
REALTIME_MAX_PUBLIC_CONNECTIONS_PER_CLIENT=3
REALTIME_HEARTBEAT_MS=25000
NOTIFICATION_RETENTION_DAYS=180
ANALYTICS_IP_HASH_SECRET=replace-with-an-independent-random-secret
ANALYTICS_RETENTION_DAYS=90

FLYWAY_ENABLED=true
FLYWAY_BASELINE_ON_MIGRATE=true
SQL_INIT_MODE=never

OFFICIAL_FRAME_SYNC_ENABLED=false
OFFICIAL_FRAME_SYNC_CRON=0 0 3 */7 * *
OFFICIAL_FRAME_SYNC_REQUEST_DELAY_MS=2500
OFFICIAL_FRAME_SYNC_BASE_URL=https://www.streetfighter.com/6/zh-hant/character
